qmake: FORCE
	@$(QMAKE) -o Makefile KeyBoardSwitcher.pro -spec macx-clang CONFIG+=debug CONFIG+=x86_64 CONFIG+=qml_debug

qmake_all: FORCE

KeyBoardSwitcher.app/Contents/PkgInfo: 
	@test -d KeyBoardSwitcher.app/Contents || mkdir -p KeyBoardSwitcher.app/Contents
	@$(DEL_FILE) KeyBoardSwitcher.app/Contents/PkgInfo
	@echo "APPL????" > KeyBoardSwitcher.app/Contents/PkgInfo
KeyBoardSwitcher.app/Contents/Resources/empty.lproj: 
	@test -d KeyBoardSwitcher.app/Contents/Resources || mkdir -p KeyBoardSwitcher.app/Contents/Resources
	@touch KeyBoardSwitcher.app/Contents/Resources/empty.lproj
	
KeyBoardSwitcher.app/Contents/Info.plist: 
	@test -d KeyBoardSwitcher.app/Contents || mkdir -p KeyBoardSwitcher.app/Contents
	@$(DEL_FILE) KeyBoardSwitcher.app/Contents/Info.plist
	@sed -e "s,@SHORT_VERSION@,1.0,g" -e "s,\$${QMAKE_SHORT_VERSION},1.0,g" -e "s,@FULL_VERSION@,1.0.0,g" -e "s,\$${QMAKE_FULL_VERSION},1.0.0,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" -e "s,@BUNDLEIDENTIFIER@,v1z.KeyBoardSwitcher,g" -e "s,\$${PRODUCT_BUNDLE_IDENTIFIER},v1z.KeyBoardSwitcher,g" -e "s,\$${MACOSX_DEPLOYMENT_TARGET},10.12,g" -e "s,\$${IPHONEOS_DEPLOYMENT_TARGET},,g" -e "s,\$${TVOS_DEPLOYMENT_TARGET},,g" -e "s,\$${WATCHOS_DEPLOYMENT_TARGET},,g" -e "s,@ICON@,logo.icns,g" -e "s,\$${ASSETCATALOG_COMPILER_APPICON_NAME},logo.icns,g" -e "s,@EXECUTABLE@,KeyBoardSwitcher,g" -e "s,@LIBRARY@,KeyBoardSwitcher,g" -e "s,\$${EXECUTABLE_NAME},KeyBoardSwitcher,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" Info.plist >KeyBoardSwitcher.app/Contents/Info.plist
KeyBoardSwitcher.app/Contents/Resources/logo.icns: logo.icns
	@test -d KeyBoardSwitcher.app/Contents/Resources/ || mkdir -p KeyBoardSwitcher.app/Contents/Resources/
	@$(DEL_FILE) KeyBoardSwitcher.app/Contents/Resources/logo.icns
	@$(COPY_FILE) logo.icns KeyBoardSwitcher.app/Contents/Resources/logo.icns

all: Makefile \
		KeyBoardSwitcher.app/Contents/PkgInfo \
		KeyBoardSwitcher.app/Contents/Resources/empty.lproj \
		KeyBoardSwitcher.app/Contents/Info.plist \
		KeyBoardSwitcher.app/Contents/Resources/logo.icns KeyBoardSwitcher.app/Contents/MacOS/KeyBoardSwitcher

dist: distdir FORCE
	(cd `dirname $(DISTDIR)` && $(TAR) $(DISTNAME).tar $(DISTNAME) && $(COMPRESS) $(DISTNAME).tar) && $(MOVE) `dirname $(DISTDIR)`/$(DISTNAME).tar.gz . && $(DEL_FILE) -r $(DISTDIR)

distdir: FORCE
	@test -d $(DISTDIR) || mkdir -p $(DISTDIR)
	$(COPY_FILE) --parents $(DIST) $(DISTDIR)/
	$(COPY_FILE) --parents imgs.qrc $(DISTDIR)/
	$(COPY_FILE) --parents /Applications/QT/5.12.6/clang_64/mkspecs/features/data/dummy.cpp $(DISTDIR)/
	$(COPY_FILE) --parents adminaccessinstructions.h mainwindow.h switchkeyboard.h utilities.h $(DISTDIR)/
	$(COPY_FILE) --parents adminaccessinstructions.cpp main.cpp mainwindow.cpp switchKeyBoard.mm utilities.cpp $(DISTDIR)/
	$(COPY_FILE) --parents adminaccessinstructions.ui mainwindow.ui $(DISTDIR)/


clean: compiler_clean 
	-$(DEL_FILE) $(OBJECTS)
	-$(DEL_FILE) *~ core *.core


distclean: clean 
	-$(DEL_FILE) -r KeyBoardSwitcher.app
	-$(DEL_FILE) Makefile


