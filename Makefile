####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/opt/KeyBoardSwitcher/bin || mkdir -p $(INSTALL_ROOT)/opt/KeyBoardSwitcher/bin
	$(DEL_FILE) -r $(INSTALL_ROOT)/opt/KeyBoardSwitcher/bin/KeyBoardSwitcher.app
	
	-$(QINSTALL) KeyBoardSwitcher.app $(INSTALL_ROOT)/opt/KeyBoardSwitcher/bin/KeyBoardSwitcher.app

uninstall_target: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/opt/KeyBoardSwitcher/bin/KeyBoardSwitcher.app
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/KeyBoardSwitcher/bin/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

